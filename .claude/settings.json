{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-deep-ref.py\"",
            "if": "Write(corpus.commons/*/references/*-deep.md)|Edit(corpus.commons/*/references/*-deep.md)|Write(corpus.local/*/references/*-deep.md)|Edit(corpus.local/*/references/*-deep.md)",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-derived-index.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/git-hooks/pre-push\"",
            "if": "Bash(*git push*)",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
